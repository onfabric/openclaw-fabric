    "/users/{user_id}/threads": {
      "get": {
        "tags": ["Users"],
        "summary": "List User Threads",
        "description": "Get threads for a user.\n\nThe thread payload is formatted as an [Activity Streams 2.0](https://www.w3.org/TR/activitystreams-core/) compliant object.\nExtension field: Some nodes may include `fibreKind` next to type. While type remains the canonical AS2 type,\nfibreKind further distinguishes our domain-specific interaction kinds (e.g., to disambiguate multiple product interactions that would otherwise share the same AS2 type).\nThis field is optional, non-standard, and safe to ignore for generic AS2 clients. We intend to publish a formal AS2 extension for these semantics.\n\n> [!NOTE]\n> If the response contains no threads, it could mean one of the following:\n>\n> - **Consent not completed**: The user hasn't completed a consent flow with any provider yet.\n>   You should either prompt the user for consent again or wait for the consent to complete.\n>   When it does, Fabric will send a callback to the URL you configured in your consent config,\n>   confirming the consent succeeded.\n> - **Data not yet available**: The user has completed the consent, but the data is still being\n>   processed on Fabric's side. You should keep polling this endpoint until threads become available.\n> - **Processing error**: There was an error during the consent flow or while processing the data\n>   on Fabric's side. Please contact Fabric support for assistance.\n\n> [!TIP]\n> If a thread has `is_asset` set to `true`, you can obtain a signed URL for the asset\n> by calling the [`/users/{user_id}/threads/{thread_id}/asset`](#tag/users/GET/users/{user_id}/threads/{thread_id}/asset) endpoint.",
        "operationId": "list_user_threads_users__user_id__threads_get",
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid4",
              "description": "The ID of the user",
              "title": "User Id"
            },
            "description": "The ID of the user"
          },
          {
            "name": "interaction_type",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter by interaction type. See GET /interaction-types for valid values.",
              "title": "Interaction Type"
            },
            "description": "Filter by interaction type. See GET /interaction-types for valid values."
          },
          {
            "name": "from_date",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date-time"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Only return threads from this date onwards",
              "title": "From Date"
            },
            "description": "Only return threads from this date onwards"
          },
          {
            "name": "to_date",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date-time"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Only return threads until this date",
              "title": "To Date"
            },
            "description": "Only return threads until this date"
          },
          {
            "name": "page_token",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Page Token"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "default": 10,
              "title": "Page Size"
            }
          },
          {
            "name": "direction",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "$ref": "#/components/schemas/PageSortDirection"
                },
                {
                  "type": "null"
                }
              ],
              "default": "desc",
              "title": "Direction"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "description": "The api key generated from the Fabric developer portal",
              "title": "X-Api-Key"
            },
            "description": "The api key generated from the Fabric developer portal"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
