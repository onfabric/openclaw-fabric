{
  "name": "@onfabric/openclaw-fabric",
  "description": "Portable AI memory for OpenClaw",
  "version": "0.0.1",
  "author": "Fabric Developers <developers@onfabric.io>",
  "repository": {
    "type": "git",
    "url": "https://github.com/onfabric/openclaw-fabric"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "index.ts",
    "package.json",
    "openclaw.plugin.json",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check:types": "bun run --bun tsc",
    "check:codestyle": "bun run --bun biome check",
    "check:all": "bun check:types && bun check:codestyle",
    "fix:codestyle": "bun run --bun biome check --write",
    "check:commit-message": "bun run --bun commitlint"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/format": "^20.5.0",
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.29"
  }
}
