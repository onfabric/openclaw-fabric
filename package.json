{
  "name": "@onfabric/openclaw-fabric",
  "description": "Portable AI memory for OpenClaw",
  "version": "0.0.25",
  "author": "Fabric Developers <developers@onfabric.io>",
  "repository": {
    "type": "git",
    "url": "https://github.com/onfabric/openclaw-fabric"
  },
  "license": "MIT",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist/*",
    "skills/*",
    "package.json",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist/ --target node",
    "check:types": "bun run --bun tsc",
    "check:codestyle": "bun run --bun biome check",
    "check:all": "bun check:types && bun check:codestyle",
    "fix:codestyle": "bun run --bun biome check --write",
    "check:commit-message": "bun run --bun commitlint",
    "generate-openapi": "bun run --bun openapi-typescript src/api/openapi.json -o src/api/openapi.ts --enum --root-types"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/format": "^20.5.0",
    "@types/bun": "latest",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.29"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.62.0",
    "@sinclair/typebox": "^0.34.48",
    "openapi-fetch": "^0.17.0"
  }
}
